# Backend URL (used by Vite dev server proxy target in vite.config.ts)
VITE_API_URL=http://127.0.0.1:8000

# Knot Web SDK (browser). Must match a Transaction Link client in the Knot dashboard;
# domain allowlist must include http://localhost:8080 for local dev.
VITE_KNOT_CLIENT_ID=
# development | production | sandbox (see knotapi-js types)
VITE_KNOT_ENVIRONMENT=development
