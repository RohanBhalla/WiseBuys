backend/**/*.sqlite3
backend/dist/
backend/build/
backend/**/*.egg-info/

# --- Frontend (Node / Vite / TanStack Start / Cloudflare) ---
frontend/node_modules/
frontend/dist/
frontend/.output/
frontend/.tanstack/
frontend/.wrangler/
